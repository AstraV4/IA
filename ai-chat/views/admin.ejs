<!DOCTYPE html>
<html lang="fr"><head>
<meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1.0" />
<title>Admin · <%= siteName %></title>
<link rel="stylesheet" href="/static/css/style.css" />
<style>
  .admin{max-width:800px;margin:5vh auto;padding:0 16px}
  table{width:100%;border-collapse:collapse;margin-top:18px;background:var(--panel);border:1px solid var(--border);border-radius:14px;overflow:hidden}
  th,td{padding:12px 14px;text-align:left;font-size:.9rem;border-bottom:1px solid var(--border)}
  th{color:var(--dim);font-weight:600;font-size:.78rem;text-transform:uppercase;letter-spacing:.04em}
  tr:last-child td{border-bottom:none}
  .mini{padding:7px 12px;font-size:.82rem;border-radius:9px}
  .stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:18px 0}
  .stat{background:var(--panel);border:1px solid var(--border);border-radius:14px;padding:16px}
  .stat-n{font-size:1.7rem;font-weight:700;color:var(--accent)}
  .stat-l{color:var(--dim);font-size:.82rem;margin-top:2px}
  .chart-card{background:var(--panel);border:1px solid var(--border);border-radius:14px;padding:18px;margin-bottom:8px}
  .chart-title{color:var(--dim);font-size:.82rem;text-transform:uppercase;letter-spacing:.04em;font-weight:600;margin-bottom:16px}
  .bars{display:flex;align-items:flex-end;gap:10px;height:150px}
  .bar-col{flex:1;display:flex;flex-direction:column;align-items:center;height:100%}
  .bar-wrap{flex:1;width:100%;display:flex;align-items:flex-end;justify-content:center}
  .bar{width:66%;min-height:3px;background:linear-gradient(180deg,var(--accent2),var(--accent));border-radius:7px 7px 0 0;position:relative;display:flex;justify-content:center}
  .bar-n{position:absolute;top:-18px;font-size:.74rem;color:var(--dim)}
  .bar-l{color:var(--dim);font-size:.78rem;margin-top:6px}
  @media(max-width:700px){.stat-grid{grid-template-columns:repeat(2,1fr)}}
</style>
</head><body>
<nav class="nav">
  <a class="brand" href="/"><span class="m"></span><%= siteName %></a>
  <div class="links"><a href="/chat">Chat</a><a href="/account">Mon compte</a></div>
</nav>

<div class="admin">
  <h2>🛠️ Panneau admin</h2>
  <p style="color:var(--dim);margin-top:6px">Quand quelqu'un t'ajoute sur Discord (<%= discordHandle %>), tu peux le passer en Pro ou réinitialiser son mot de passe ici.</p>

  <div class="stat-grid">
    <div class="stat"><div class="stat-n"><%= stats.users %></div><div class="stat-l">Utilisateurs</div></div>
    <div class="stat"><div class="stat-n"><%= stats.active7 %></div><div class="stat-l">Actifs (7 jours)</div></div>
    <div class="stat"><div class="stat-n"><%= stats.pro %></div><div class="stat-l">Comptes Pro</div></div>
    <div class="stat"><div class="stat-n"><%= stats.newUsers7 %></div><div class="stat-l">Nouveaux (7 j)</div></div>
    <div class="stat"><div class="stat-n"><%= stats.convs %></div><div class="stat-l">Conversations</div></div>
    <div class="stat"><div class="stat-n"><%= stats.questions %></div><div class="stat-l">Questions posées</div></div>
    <div class="stat"><div class="stat-n"><%= stats.msgsTotal %></div><div class="stat-l">Messages (total)</div></div>
    <div class="stat"><div class="stat-n"><%= stats.msgsToday %></div><div class="stat-l">Messages aujourd'hui</div></div>
  </div>

  <div class="chart-card">
    <div class="chart-title">📈 Messages des 7 derniers jours</div>
    <div class="bars">
      <% stats.days.forEach(function(d){ %>
        <div class="bar-col">
          <div class="bar-wrap"><div class="bar" style="height:<%= Math.round(d.n / stats.maxDay * 100) %>%"><span class="bar-n"><%= d.n %></span></div></div>
          <div class="bar-l"><%= d.label %></div>
        </div>
      <% }) %>
    </div>
  </div>

  <% if (notice) { %>
    <div class="ok" style="margin-top:16px">
      🔑 Mot de passe temporaire pour <b><%= notice.email %></b> : <b style="font-family:monospace;font-size:1.05rem"><%= notice.temp %></b>
      <div style="color:var(--dim);font-size:.85rem;margin-top:4px">Envoie-le-lui sur Discord. Il pourra le changer dans « Mon compte ».</div>
    </div>
  <% } %>

  <table>
    <tr><th>ID</th><th>E-mail</th><th>Forfait</th><th>Messages</th><th>Forfait</th><th>Mot de passe</th></tr>
    <% users.forEach(function(u){ %>
      <tr>
        <td><%= u.id %></td>
        <td><%= u.email %></td>
        <td><span class="tag <%= u.plan==='pro'?'pro':'' %>"><%= u.plan==='pro'?'PRO':'GRATUIT' %></span></td>
        <td><%= u.msg_used %> / <%= u.plan==='pro'?proLimit:freeLimit %></td>
        <td>
          <form method="POST" action="/admin/setplan" style="display:inline">
            <input type="hidden" name="userId" value="<%= u.id %>" />
            <% if (u.plan==='pro') { %>
              <input type="hidden" name="plan" value="free" />
              <button class="btn btn-danger mini" type="submit">Repasser Gratuit</button>
            <% } else { %>
              <input type="hidden" name="plan" value="pro" />
              <button class="btn-primary btn mini" type="submit">Passer Pro</button>
            <% } %>
          </form>
        </td>
        <td>
          <form method="POST" action="/admin/resetpw" style="display:inline" onsubmit="return confirm('Réinitialiser le mot de passe de <%= u.email %> ?')">
            <input type="hidden" name="userId" value="<%= u.id %>" />
            <button class="btn mini" type="submit">🔑 Réinit.</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>
</div>
</body></html>
