<!DOCTYPE html>
<html lang="fr"><head>
<meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1.0" />
<title>Chat · <%= siteName %></title>
<link rel="stylesheet" href="/static/css/style.css" />
<script>try{if(localStorage.getItem('theme')==='dark')document.documentElement.setAttribute('data-theme','dark');}catch(e){}</script>
</head><body class="chat-body">
<div class="app">
  <div class="side-overlay" id="side-overlay"></div>
  <aside class="side" id="side">
    <div class="side-top">
      <a class="logo" href="/"><span class="m"></span><%= siteName %></a>
    </div>
    <button class="new" id="new-conv"><span class="plus">＋</span> Nouvelle conversation</button>
    <a class="side-link nav-link" href="/correction">✍️ Correction de texte</a>
    <input class="conv-search" id="conv-search" placeholder="🔎 Rechercher…" />
    <div class="lbl">Récents</div>
    <div class="conv-list" id="conv-list">
      <% conversations.forEach(function(c){ %>
        <a class="conv <%= c.id===currentId?'active':'' %> <%= c.pinned?'pinned':'' %>" href="/chat?c=<%= c.id %>" data-id="<%= c.id %>">
          <span class="conv-t"><%= c.title || 'Conversation' %></span>
          <span class="conv-actions">
            <button class="conv-pin <%= c.pinned?'on':'' %>" type="button" data-pin="<%= c.id %>" title="<%= c.pinned?'Désépingler':'Épingler' %>">📌</button>
            <button class="conv-edit" type="button" data-edit="<%= c.id %>" title="Renommer">✏️</button>
            <button class="conv-del" type="button" data-del="<%= c.id %>" title="Supprimer">🗑</button>
          </span>
        </a>
      <% }) %>
    </div>
    <div class="side-foot">
      <button class="side-link" type="button" id="theme-toggle">🌙 Thème sombre</button>
      <button class="side-link" type="button" id="export-btn">⬇️ Exporter la conversation</button>
      <% if (isAdmin) { %><a class="side-link" href="/admin">🛠️ Espace admin</a><% } %>
      <div class="quota-mini">
        <% if (me.plan === 'pro') { %><span class="tag pro">PRO</span><% } else { %><span class="tag">GRATUIT</span><% } %>
        <span class="qm-txt"><b id="used"><%= used %></b> / <%= limit %></span>
        <% if (me.plan !== 'pro') { %><a class="qm-up" href="/account">Pro →</a><% } %>
      </div>
      <a class="acct" href="/account">
        <span class="av"><%= (me.email||'?').charAt(0).toUpperCase() %></span>
        <span class="who"><%= me.email %><small>Forfait <%= me.plan === 'pro' ? 'Pro' : 'gratuit' %></small></span>
      </a>
      <form method="POST" action="/logout"><button class="side-link" type="submit">↩ Déconnexion</button></form>
    </div>
  </aside>

  <main class="main">
    <div class="main-top"><button class="menu-btn" id="menu-btn" title="Menu">☰</button></div>

    <div class="thread" id="messages">
      <% if (!history.length) { %>
        <div class="empty" id="empty">
          <div class="empty-icon">✦</div>
          <h3>Bonjour !</h3>
          <p>Pose ta question, ou joins un fichier (image, PDF, texte…) pour que je t'aide.</p>
          <div class="suggests">
            <button class="sug" data-text="Corrige l'orthographe et la grammaire de ce texte : ">✍️ Corriger un texte</button>
            <button class="sug" data-text="Explique-moi simplement : ">💡 Expliquer un concept</button>
            <button class="sug" data-text="Résume-moi ce document : ">📄 Résumer un document</button>
            <button class="sug" data-text="Aide-moi à coder : ">💻 Aider à coder</button>
          </div>
        </div>
      <% } %>
      <% history.forEach(function(m){ %>
        <% if (m.role === 'user') { %>
          <div class="turn user"><div class="bubble"><%= m.content %></div></div>
        <% } else { %>
          <div class="turn ai"><div class="av">✦</div><div class="body md-raw"><%= m.content %></div></div>
        <% } %>
      <% }) %>
    </div>

    <div class="composer-wrap">
      <div class="preview" id="preview" hidden>
        <img id="preview-img" alt="aperçu" hidden />
        <div class="filechip" id="preview-chip" hidden><span class="fi" id="preview-icon">📄</span><span class="fn" id="preview-name"></span></div>
        <button type="button" id="preview-remove" title="Retirer">✕</button>
      </div>
      <div class="voice-bar" id="voice-bar" hidden><span class="dot"></span> Je t'écoute… <button type="button" id="voice-stop">Stop</button></div>
      <div class="composer">
        <textarea id="input" placeholder="Écris ton message à <%= siteName %>…" rows="1"></textarea>
        <div class="c-row">
          <div class="c-left">
            <input type="file" id="file" hidden />
            <button class="tool" id="attach" title="Joindre un fichier">📎</button>
          </div>
          <div class="c-right">
            <button class="tool" id="mic" title="Dicter à la voix">🎤</button>
            <button class="tool" id="speak" title="Lire les réponses à voix haute">🔊</button>
            <button class="tool wave" id="voice-mode" title="Mode vocal (conversation mains libres)"><span></span><span></span><span></span><span></span></button>
            <button class="send" id="send" title="Envoyer">➤</button>
          </div>
        </div>
      </div>
      <div class="hint"><%= siteName %> peut faire des erreurs. Vérifie les informations importantes.</div>
    </div>
  </main>
</div>

<div class="voice-overlay" id="voice-overlay" hidden>
  <div class="voice-panel">
    <div class="orb" id="voice-orb"><span></span><span></span><span></span><span></span><span></span></div>
    <div class="voice-status" id="voice-status">Initialisation…</div>
    <div class="voice-live" id="voice-live"></div>
    <button class="voice-close" id="voice-close">Terminer</button>
  </div>
</div>

<div class="modal-overlay" id="modal" hidden>
  <div class="modal">
    <h3 id="modal-title"></h3>
    <p id="modal-msg" class="modal-msg" hidden></p>
    <input id="modal-input" class="modal-input" hidden />
    <div class="modal-actions">
      <button class="btn" type="button" id="modal-cancel">Annuler</button>
      <button class="btn-primary btn" type="button" id="modal-ok">OK</button>
    </div>
  </div>
</div>

<script>window.LIMIT = <%= limit %>; window.CURRENT = <%= currentId || 'null' %>;</script>
<script src="/static/js/chat.js"></script>
</body></html>
