<!DOCTYPE html>
<html lang="fr"><head>
<meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1.0" />
<title>Connexion · <%= siteName %></title>
<link rel="stylesheet" href="/static/css/style.css" />
</head><body>
<nav class="nav"><a class="brand" href="/"><span class="m"></span><%= siteName %></a></nav>
<div class="auth">
  <h2>Connexion</h2>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <form method="POST" action="/login">
    <label>E-mail</label>
    <input type="email" name="email" value="<%= email %>" required />
    <label>Mot de passe</label>
    <input type="password" name="password" required />
    <button class="btn-primary" type="submit">Se connecter</button>
  </form>
  <div class="alt">Pas de compte ? <a href="/register">S'inscrire</a></div>
  <div class="alt" style="margin-top:8px"><a href="/forgot">Mot de passe oublié ?</a></div>
</div>
</body></html>
